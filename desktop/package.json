{
  "name": "j1ms-bot-desktop",
  "version": "0.1.0",
  "private": true,
  "description": "Vanta desktop app — local Kmart checkout (localhost proxies, API-key license, store adapters).",
  "main": "main.cjs",
  "scripts": {
    "start": "electron .",
    "test": "node --test keyword-parse.test.cjs kmart-stock-probe.test.cjs global-matcher.test.cjs",
    "install-browsers": "cd ../executor && npx playwright install chromium",
    "install-executor": "cd ../executor && npm install",
    "setup": "npm install && npm run install-executor && npm run install-browsers",
    "package:linux": "electron-packager . Vanta --platform=linux --arch=x64 --out=release --overwrite --icon=renderer/assets/icon.png",
    "package:mac": "electron-packager . Vanta --platform=darwin --arch=x64 --out=release --overwrite --icon=renderer/assets/icon.png",
    "package:win": "electron-packager . Vanta --platform=win32 --arch=x64 --out=release --overwrite --icon=renderer/assets/icon.png"
  },
  "dependencies": {},
  "devDependencies": {
    "electron": "^32.0.0",
    "@electron/packager": "^18.3.5"
  }
}
