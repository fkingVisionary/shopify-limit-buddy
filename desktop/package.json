{
  "name": "j1ms-bot-desktop",
  "version": "0.1.0",
  "private": true,
  "description": "J1m's Bot desktop app — local Kmart checkout (localhost proxies, API-key license, store adapters).",
  "main": "main.cjs",
  "scripts": {
    "start": "electron .",
    "install-browsers": "cd ../executor && npx playwright install chromium",
    "install-executor": "cd ../executor && npm install",
    "setup": "npm install && npm run install-executor && npm run install-browsers",
    "package:linux": "electron-packager . J1msBot --platform=linux --arch=x64 --out=release --overwrite",
    "package:mac": "electron-packager . J1msBot --platform=darwin --arch=x64 --out=release --overwrite",
    "package:win": "electron-packager . J1msBot --platform=win32 --arch=x64 --out=release --overwrite"
  },
  "dependencies": {},
  "devDependencies": {
    "electron": "^32.0.0",
    "@electron/packager": "^18.3.5"
  }
}
